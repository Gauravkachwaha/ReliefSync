MONGO_URL=your_mongodb_connection_string
PORT=5000
NODE_ENV=development
# Production: your live frontend origin(s), comma-separated (no trailing slash). Required for browser API calls.
# FRONTEND_URL=https://your-app.vercel.app
JWT_SECRET=your_jwt_secret_key
OPENAI_API_KEY=your_openai_api_key
# Optional: Gmail (app password) for critical alerts and assignment emails
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Internal FastAPI AI service
AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_API_KEY=your_internal_fastapi_secret
AI_SERVICE_TIMEOUT_MS=10000


#For the super admin
SUPER_ADMIN_NAME=ReliefSync Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change_this_before_deployment


VOLUNTEER_OFFER_EXPIRY_MINUTES=15